# DemoTrack environment — copy to .env.local and fill in. NEVER commit real keys.

# Supabase (Project Settings → API). Only the anon/public key belongs in the client;
# Row-Level Security is what actually protects your data.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Where magic-link emails redirect back to (your deployed app URL in prod).
VITE_SITE_URL=http://localhost:5173

# --- Server-side only (Supabase Edge Functions / scripts) — do NOT prefix with VITE_ ---
# Anthropic API key powers the 3 AI features (email hook, bio, feedback patterns).
# Keep this out of the client bundle; call Claude from an Edge Function.
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=...   # for seed scripts only, never in the browser

# Phase 11 (optional) — base URL for tracked demo links (Form/DM only).
# Defaults to the deployed track-redirect function; set a custom subdomain in prod.
# VITE_TRACK_BASE_URL=https://track.demotrack.app
